{
  "name": "wildchat",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=web --filter=realtime",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.4.2"
}
